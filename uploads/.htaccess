# Sécurité : interdire l'exécution de scripts dans le dossier des uploads
php_flag engine off
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phar|cgi|pl|py|sh)$">
  Require all denied
</FilesMatch>

# N'autoriser que les images
<FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
  Require all granted
</FilesMatch>
